# =========================
# {{PRODUCT_NAME}} — env (TEMPLATE — placeholders only)
# =========================
# This file is committed; it documents the variable NAMES, never values.
# Copy to .env.local and fill. .env / .env*.local are gitignored.
# Real secrets live in a secret manager / platform env (Vercel project
# settings), NEVER committed to git. See SETUP.md for the 11-step checklist.
#
# LOCAL-FIRST: you need NONE of these to start. `bun dev` boots with zero env —
# the app runs in local mode (dev-auth stub, no external calls). Add a key only
# when you want that capability; add Supabase to switch off local mode.

# --- App ---
NEXT_PUBLIC_APP_NAME={{PRODUCT_NAME}}
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs (one per tier; expose only to server)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# --- Resend ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=hi@{{PRODUCT_DOMAIN}}

# --- Analytics ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GSC_VERIFICATION=

# --- Sentry ---
# DSN is what makes Sentry actually run. Unset = the SDK never inits (local default).
NEXT_PUBLIC_SENTRY_DSN=
# AUTH_TOKEN/ORG/PROJECT are build-time only — they upload source maps, they do NOT
# turn Sentry on. Setting them without a DSN is exactly how this starter once shipped
# an observability costume that captured nothing.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Shared secret for /api/debug/sentry-canary (verify-live.ts A11). Unset = the route
# 404s and does not exist. Set it in prod to make "errors reach Sentry" provable:
#   bun scripts/verify-live.ts https://yourdomain.com --canary-token <this value>
SENTRY_CANARY_TOKEN=

# --- AI ---
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=


# --- SEO data (optional) ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
