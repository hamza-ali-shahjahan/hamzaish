# Dashboard reads metrics across all products. Add credentials here for the
# connectors. Per-product config (which keys to use, IDs) lives in each
# products/<slug>/product.config.json.

# Stripe — single account that holds all products' subscriptions
STRIPE_SECRET_KEY=

# PostHog — single org with one project per product
POSTHOG_PERSONAL_API_KEY=
POSTHOG_HOST=https://us.posthog.com

# Sentry
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# Google Search Console — OAuth flow recommended; see lib/connectors/gsc.ts
GOOGLE_SERVICE_ACCOUNT_KEY=

# Plausible
PLAUSIBLE_API_KEY=
