# Hamzaish — root .gitignore
# brain.db is gitignored at brain/.gitignore (it's derived state)

# Reference repos — re-cloned by scripts/install-references.sh, not tracked
references/gbrain/
references/hermes-agent/
references/openclaw/

# Node / build artifacts
node_modules/
dist/
build/
.next/
.turbo/
.wrangler/
out/
.cache/

# Environment / secrets — never commit
.env
.env.*
!.env.example
*.env.local
*.env.production

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# Logs
*.log
logs/

# Test output
coverage/
.nyc_output/

# Bun
bun-debug.log
.bun-cache/

# Local-only product code-path map (machine-specific; never commit)
code-paths.local.json

# Local-only operator overrides — personal identity / preferences / context
# Pattern: *.local.<ext> stays on disk but never reaches the repo.
# Templates are committed as *.example.<ext> for forks to copy.
brain/identity/*.local.md
**/*.local.md
**/*.local.json
!**/*.example.local.md  # safety: don't accidentally ignore example files

# Auto-commit/push opt-out markers (operator discipline; not source code)
.no-auto-commit
.no-auto-push
.no-auto-pull

# Operator-local research (competitive/strategy docs — never committed)
meta/research/
