<!-- ============== SEO + AEO FOUNDATION — generated by /seo-aeo-bootstrap ============== -->
<title>{{ProductName}} — {{OneLineValueProp}}</title>
<meta name="description" content="{{MetaDescription}}" />
<link rel="canonical" href="{{Domain}}/" />
<meta name="robots" content="index, follow" />
<meta name="author" content="{{FounderName}}" />
<meta name="application-name" content="{{ProductName}}" />

<!-- Open Graph -->
<meta property="og:title" content="{{ProductName}} — {{OneLineValueProp}}" />
<meta property="og:description" content="{{MetaDescription}}" />
<meta property="og:type" content="website" />
<meta property="og:url" content="{{Domain}}/" />
<meta property="og:site_name" content="{{ProductName}}" />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content="{{Domain}}/og-image.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="{{OGImageAlt}}" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ProductName}} — {{OneLineValueProp}}" />
<meta name="twitter:description" content="{{MetaDescription}}" />
<meta name="twitter:image" content="{{Domain}}/og-image.png" />

<!-- AEO / LLM discovery -->
<link rel="alternate" type="text/markdown" href="/llms.txt" title="{{ProductName}} for LLMs" />

<!-- JSON-LD graph: Person → Organization → WebSite → WebPage → SoftwareApplication → FAQPage -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "{{Domain}}/#founder",
      "name": "{{FounderName}}",
      "jobTitle": "Founder",
      "description": "{{FounderBio}}",
      "url": "{{FounderURL}}",
      "sameAs": [
        "{{FounderLinkedIn}}",
        "{{FounderGitHub}}"
      ]
    },
    {
      "@type": "Organization",
      "@id": "{{Domain}}/#organization",
      "name": "{{ProductName}}",
      "url": "{{Domain}}/",
      "logo": "{{Domain}}/apple-touch-icon.png",
      "image": "{{Domain}}/og-image.png",
      "description": "{{MetaDescription}}",
      "founder": { "@id": "{{Domain}}/#founder" },
      "sameAs": [
        "{{RepoURL}}",
        "{{FounderLinkedIn}}"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "{{Domain}}/#website",
      "url": "{{Domain}}/",
      "name": "{{ProductName}}",
      "description": "{{MetaDescription}}",
      "publisher": { "@id": "{{Domain}}/#organization" },
      "inLanguage": "en"
    },
    {
      "@type": "WebPage",
      "@id": "{{Domain}}/#webpage",
      "url": "{{Domain}}/",
      "name": "{{ProductName}} — {{OneLineValueProp}}",
      "isPartOf": { "@id": "{{Domain}}/#website" },
      "about": { "@id": "{{Domain}}/#organization" },
      "primaryImageOfPage": "{{Domain}}/og-image.png",
      "inLanguage": "en",
      "author": { "@id": "{{Domain}}/#founder" }
    },
    {
      "@type": "SoftwareApplication",
      "@id": "{{Domain}}/#software",
      "name": "{{ProductName}}",
      "applicationCategory": "{{ApplicationCategory}}",
      "operatingSystem": "{{OperatingSystem}}",
      "description": "{{SoftwareDescription}}",
      "url": "{{Domain}}/",
      "author": { "@id": "{{Domain}}/#founder" },
      "license": "https://opensource.org/licenses/MIT",
      "codeRepository": "{{RepoURL}}",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "FAQPage",
      "@id": "{{Domain}}/#faq",
      "mainEntity": [
        { "@type": "Question", "name": "What is {{ProductName}}?",
          "acceptedAnswer": { "@type": "Answer", "text": "{{FAQ_What}}" } },
        { "@type": "Question", "name": "Who is {{ProductName}} for?",
          "acceptedAnswer": { "@type": "Answer", "text": "{{FAQ_Who}}" } },
        { "@type": "Question", "name": "{{FAQ_AdoptionQuestion}}",
          "acceptedAnswer": { "@type": "Answer", "text": "{{FAQ_Adoption}}" } },
        { "@type": "Question", "name": "When is {{ProductName}} available?",
          "acceptedAnswer": { "@type": "Answer", "text": "{{FAQ_Availability}}" } },
        { "@type": "Question", "name": "Is {{ProductName}} open source?",
          "acceptedAnswer": { "@type": "Answer", "text": "{{FAQ_License}}" } },
        { "@type": "Question", "name": "Who built {{ProductName}}?",
          "acceptedAnswer": { "@type": "Answer", "text": "{{FAQ_Founder}}" } }
      ]
    }
  ]
}
</script>
<!-- ============== END SEO + AEO FOUNDATION ============== -->
