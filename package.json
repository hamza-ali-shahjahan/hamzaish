    "check-validation": "bun scripts/check-validation.ts",
    "check-gates": "bun scripts/check-gates.ts",
    "eval": "bun meta/evals/run.ts",
    "bench": "bun meta/evals/run.ts --models opus,sonnet,haiku",
    "test": "bun test ./factory ./scripts ./dashboard ./meta",
    "check-changelog": "bun scripts/check-changelog.ts",
    "credits": "bun scripts/credits.ts",
    "hero": "bun scripts/hero.ts",
    "check-assets": "bun scripts/check-assets.ts",
    "check-starter": "bun scripts/check-starter.ts",
    "check-product-layout": "bun scripts/check-product-layout.ts",
    "check-skill-command-collision": "bun scripts/check-skill-command-collision.ts",
    "check-counts": "bun scripts/check-counts.ts",
    "check-evals": "bun scripts/check-evals.ts",
    "check-model-independence": "bun scripts/check-model-independence.ts",
    "check-retro": "bun scripts/check-retro.ts",
    "check-sensitive-docs": "bun scripts/check-sensitive-docs.ts",
    "telemetry": "bun scripts/telemetry.ts",
    "friction": "bun scripts/friction.ts",
    "reward": "bun scripts/reward.ts",
    "trace-report": "bun scripts/trace-report.ts",
    "tidy": "bun scripts/tidy.ts"
